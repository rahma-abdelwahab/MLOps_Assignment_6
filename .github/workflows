name: ML Validation & Deployment Pipeline

on:
  push:
    branches:
      - main
  workflow_dispatch:
    inputs:
      accuracy_override:
        description: "Override accuracy value (e.g. 0.70 to force a fail)"
        required: false
        default: ""

jobs:

  validate:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Python 3.10
        uses: actions/setup-python@v5
        with:
          python-version: "3.10"

      - name: Install dependencies
        run: pip install -r requirements.txt

      - name: Pull data with DVC
        env:
          DAGSHUB_USERNAME: ${{ secrets.DAGSHUB_USERNAME }}
          DAGSHUB_TOKEN: ${{ secrets.DAGSHUB_TOKEN }}
        run: |
          dvc remote add -f myremote https://dagshub.com/${{ secrets.DAGSHUB_USERNAME }}/MLOps_Assignment_55.dvc
          dvc remote modify myremote auth basic
          dvc remote modify myremote user ${{ secrets.DAGSHUB_USERNAME }}
          dvc remote modify myremote password ${{ secrets.DAGSHUB_TOKEN }}
          dvc remote default myremote
          dvc pull --force -v

      - name: Train model
        env:
          MLFLOW_TRACKING_URI: ${{ secrets.MLFLOW_TRACKING_URI }}
          MLFLOW_TRACKING_USERNAME: ${{ secrets.MLFLOW_TRACKING_USERNAME }}
          MLFLOW_TRACKING_PASSWORD: ${{ secrets.MLFLOW_TRACKING_PASSWORD }}
        run: |
          OVERRIDE="${{ github.event.inputs.accuracy_override }}"
          if [ -n "$OVERRIDE" ]; then
            python train.py --accuracy-override $OVERRIDE
          else
            python train.py
          fi

      - name: Verify model_info.txt exists
        run: cat model_info.txt

      - name: Upload model info artifact
        uses: actions/upload-artifact@v4
        with:
          name: model-info
          path: model_info.txt

  deploy:
    runs-on: ubuntu-latest
    needs: validate

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Python 3.10
        uses: actions/setup-python@v5
        with:
          python-version: "3.10"

      - name: Install dependencies
        run: pip install -r requirements.txt

      - name: Download model info artifact
        uses: actions/download-artifact@v4
        with:
          name: model-info

      - name: Check accuracy threshold
        env:
          MLFLOW_TRACKING_URI: ${{ secrets.MLFLOW_TRACKING_URI }}
          MLFLOW_TRACKING_USERNAME: ${{ secrets.MLFLOW_TRACKING_USERNAME }}
          MLFLOW_TRACKING_PASSWORD: ${{ secrets.MLFLOW_TRACKING_PASSWORD }}
        run: python check_threshold.py

      - name: Mock Docker Build
        if: success()
        run: |
          RUN_ID=$(cat model_info.txt)
          echo "Building Docker image for Run ID: ${RUN_ID}"
          docker build --build-arg RUN_ID="${RUN_ID}" -t breast-cancer-model:${RUN_ID} .
          echo "✅ Docker image built successfully for Run ID: ${RUN_ID}"
